services:
  wordpress:
    image: nexus-docker.dev.ng.simspace.lan/simspace/wordpress-pv:latest
    restart: always
    # Bound to localhost only — host nginx (managed by the billing_site role)
    # reverse-proxies billing.voltgrid.com → 127.0.0.1:5000 and everything
    # else → 127.0.0.1:8080 here. 443/8443 binding dropped; cyber-range
    # traffic is plain HTTP.
    ports:
      - "127.0.0.1:8080:8080"
    environment:
      enabled: "false"
      ALLOW_EMPTY_PASSWORD: "yes"
      PHP_MEMORY_LIMIT: 512M
      MARIADB_HOST: db
      WORDPRESS_DATABASE_NAME: wp
      WORDPRESS_DATABASE_USER: wp
      WORDPRESS_DATABASE_PASSWORD: simspace1
      WORDPRESS_PLUGINS: wp-statistics, 3dprint-lite
    volumes:
      - wordpress:/bitnami/wordpress
    depends_on:
      - db

  db:
    image: nexus-docker.dev.ng.simspace.lan/mariadb:10.6.4-focal
    restart: always
    environment:
      MYSQL_ROOT_USER: root
      MYSQL_ROOT_PASSWORD: simspace1
      MYSQL_DATABASE: wp
      MYSQL_USER: wp
      MYSQL_PASSWORD: simspace1
    volumes:
      - db:/var/lib/mysql

volumes:
  wordpress:
  db:
