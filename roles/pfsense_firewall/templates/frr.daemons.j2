zebra=yes
bgpd={% if pfsense_bgp is defined %}yes{% else %}no{% endif %}

ospfd={% if pfsense_ospf is defined %}yes{% else %}no{% endif %}

ospf6d=no
ripd=no
ripngd=no
isisd=no
pimd=no
ldpd=no
nhrpd=no
eigrpd=no
babeld=no
sharpd=no
pbrd=no
bfdd=no
fabricd=no
vrrpd=no
pathd=no

vtysh_enable=yes
zebra_options="-A 127.0.0.1 -s 90000000"
