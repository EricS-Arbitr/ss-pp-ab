!
! /var/etc/frr/frr.conf for {{ pfsense_hostname }} ({{ inventory_hostname }})
! Managed by pfsense_firewall role. Do not edit by hand.
! Generated from host_vars `pfsense_bgp` and dropped into the pfSense FRR
! package's expected config dir; loaded by the rc.d/frr script on start.
!
frr defaults traditional
hostname {{ pfsense_hostname }}
log syslog informational
service integrated-vtysh-config
!
ip forwarding
!
router bgp {{ pfsense_bgp.asn }}
 bgp router-id {{ pfsense_bgp.router_id }}
 no bgp default ipv4-unicast
{% for nbr in pfsense_bgp.neighbors %}
 neighbor {{ nbr.peer_ip }} remote-as {{ nbr.remote_as }}
{% if nbr.description is defined %}
 neighbor {{ nbr.peer_ip }} description {{ nbr.description }}
{% endif %}
{% endfor %}
 !
 address-family ipv4 unicast
{% for nbr in pfsense_bgp.neighbors %}
  neighbor {{ nbr.peer_ip }} activate
{% endfor %}
  redistribute connected
  redistribute static
 exit-address-family
!
line vty
!
